# Food photography image provider keys (Optional)
# If provided, the app will search live plated photos. Otherwise, it uses high-end preloaded fallback images.
VITE_UNSPLASH_ACCESS_KEY=
VITE_PEXELS_API_KEY=

# Firebase Client-Side Configuration (Optional - fallback is secure and won't trigger GitHub scanners)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Secure Payment Gateway Keys (Server-Side only - NEVER prefix with VITE_)
# Keep these out of public source code and supply them as secure environment variables in hosting consoles.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
